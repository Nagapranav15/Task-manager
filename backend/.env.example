# Environment mode (production, development)
NODE_ENV=production

# MongoDB connection string
MONGO_URL=mongodb+srv://username:password@cluster.mongodb.net/dbname

# JWT authentication secret
JWT_SECRET=your_jwt_secret_key

# Admin registration invite token
ADMIN_INVITE_TOKEN=your_admin_invite_token

# Port for the server to listen on
PORT=8080

# Primary client origin URL
CLIENT_URL=https://tasks-tracker.thinklabdigitalsolutions.com

# Multi-origin list for CORS (comma-separated URLs)
CLIENT_URLS=https://task-manager-topaz-pi.vercel.app,https://tasks-tracker.thinklabdigitalsolutions.com

# Google OAuth Client Credentials
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret_key
GOOGLE_CALLBACK_URL=https://tasks-tracker.thinklabdigitalsolutions.com/auth/google/callback
